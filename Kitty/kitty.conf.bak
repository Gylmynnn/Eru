include skwd-theme.conf
include skwd-tabs.conf
include theme.conf
include tabstyle.conf

# tab_bar_style custom
# tab_bar_min_tabs 1
modify_font cell_width 98%
modify_font cell_height 4px
enable_audio_bell no
font_size 19.0
window_padding_width 0
placement_strategy top-left
# window_margin_width 0 10 10 10
window_margin_width 10 10 10 10
cursor_trail 3
cursor_trail_decay 0.1 0.4


background_opacity 1.00
# background_opacity 0.90
enable_scrollback 0

# BEGIN_KITTY_FONTS
font_family      family="Iosevka Nerd Font Mono"
bold_font        auto
italic_font      auto
bold_italic_font auto
# END_KITTY_FONTS
# font_weight      bold


# Backup First Settings
# modify_font cell_width 90%
# modify_font cell_height 3px
