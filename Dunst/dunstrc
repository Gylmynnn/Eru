[Service]
ExecStart=dunst -config /home/ligichi/.config/dunst/dunstrc

[global]
    monitor = 0
    follow = mouse
    enable_posix_regex = true
    origin = top-right
    offset = (18, 22)
    width = (400, 720)
    transparency = 0
    notification_limit = 5
    separator_height = 10
    separator_color = "#232a2d"
    padding = 18
    horizontal_padding = 16
    text_icon_padding = 14
    gap_size = 20
    frame_width = 3
    corner_radius = 10
    sort = yes
    idle_threshold = 120

    font = Iosevka Nerd Font 12

    markup = full

    # Icon nerd font di kiri appname, layout mirip referensi
    format = "<span><span foreground='#67b0e8' size='x-large'>󱨈  </span><span foreground='#67b0e8' size='x-large' letter_spacing='-1500'><b>%a</b></span></span>\n<span size='x-large' letter_spacing='-1500' foreground='#8ccf7e'><b>ンタ %s </b></span><span size='x-large' letter_spacing='-1500'><b>%b</b></span>"

    alignment = left
    vertical_alignment = top
    show_age_threshold = -1
    word_wrap = yes
    ignore_newline = no
    stack_duplicates = false
    hide_duplicate_count = true
    show_indicators = no


    icon_position = right
    min_icon_size = 66
    max_icon_size = 66
    icon_corner_radius = 0
    icon_path = /home/ligichi/.config/dunst/icons
    enable_recursive_icon_lookup = true
    icon_theme = Papirus-Dark, Adwaita
    default_icon = dialog-information

    sticky_history = yes
    history_length = 20
    dmenu = rofi -dmenu -p dunst:
    browser = xdg-open
    always_run_script = true

    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

    close = ctrl+space
    close_all = ctrl+shift+space
    history = ctrl+grave
    context = ctrl+shift+period

[urgency_low]
    background = "#141b1e"
    foreground = "#dadada"
    frame_color = "#232a2d"
    timeout = 8

[urgency_normal]
    background = "#141b1e"
    foreground = "#dadada"
    frame_color = "#232a2d"
    timeout = 8

[urgency_critical]
    background = "#1a0f12"
    foreground = "#ffb4b4"
    frame_color = "#d66b7b"
    timeout = 8
